# Lokal ishlab chiqish uchun (SQLite):
DATABASE_URL=sqlite:///./handball.db

# Railway / production uchun (PostgreSQL) — Railway avtomatik beradi:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT maxfiy kaliti — productionda uzun tasodifiy qator qo'ying:
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Token amal qilish muddati (daqiqa) — 10080 = 7 kun:
ACCESS_TOKEN_EXPIRE_MINUTES=10080
